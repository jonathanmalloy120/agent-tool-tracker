# Snowplow Claude Code Hooks — Collector Configuration
# Copy this file to snowplow-config.env and set your collector URL.
# snowplow-config.env should NOT be committed to version control.

# Your Snowplow collector endpoint (required).
# For local testing with Snowplow Micro: http://0.0.0.0:9090
# For production: https://collector.your-domain.com
SNOWPLOW_COLLECTOR_URL=http://0.0.0.0:9090
